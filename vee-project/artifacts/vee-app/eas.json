{
  "cli": {
    "version": ">= 16.0.0",
    "requireCommit": false,
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "PNPM_FLAGS": "--no-frozen-lockfile",
        "EXPO_PUBLIC_AGORA_TOKEN_SERVER_URL": "https://your-vercel-project.vercel.app/api"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "PNPM_FLAGS": "--no-frozen-lockfile",
        "EXPO_PUBLIC_AGORA_TOKEN_SERVER_URL": "https://your-vercel-project.vercel.app/api"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "PNPM_FLAGS": "--no-frozen-lockfile",
        "EXPO_PUBLIC_AGORA_TOKEN_SERVER_URL": "https://your-vercel-project.vercel.app/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
